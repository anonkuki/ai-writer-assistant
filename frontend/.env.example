# ==========================================
# 前端运行模式说明
# 1) Vite 开发代理模式（推荐）：保持 VITE_API_URL 为空，走 /api 代理
# 2) 直连后端模式（如 Electron / 部署环境）：设置为后端地址，例如 http://localhost:3001
# ==========================================

# API 基础地址（可留空，留空时默认走同域名 /api 反代）
VITE_API_URL=

# Socket 命名空间地址（可留空，留空时默认走当前域名 /documents）
VITE_SOCKET_URL=
